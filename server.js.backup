// ==================== CANCEL ORDER ENDPOINT ====================
app.post('/api/order/cancel', (req, res) => {
    const sessionId = req.headers['x-session-id'];
    const { orderId } = req.body;
    
    console.log('\n' + '='.repeat(50));
    console.log('📝 CANCEL ORDER REQUEST');
    console.log(`Order ID: ${orderId}`);
    console.log(`Session ID: ${sessionId}`);
    
    // Check session
    if (!sessionId) {
        console.log('❌ No session ID');
        return res.status(401).json({ success: false, error: 'Please login first' });
    }
    
    // Validate session
    const sessions = readJSON(SESSIONS_FILE);
    const session = sessions[sessionId];
    
    if (!session) {
        console.log('❌ Invalid or expired session');
        return res.status(401).json({ success: false, error: 'Session expired. Please login again.' });
    }
    
    console.log(`👤 User: ${session.mobile} (${session.userId})`);
    
    // Read orders
    let orders = readJSON(ORDERS_FILE);
    console.log(`📦 Total orders in DB: ${orders.length}`);
    
    // Find order
    const orderIndex = orders.findIndex(o => o.orderId === orderId);
    
    if (orderIndex === -1) {
        console.log(`❌ Order not found: ${orderId}`);
        return res.status(404).json({ success: false, error: 'Order not found' });
    }
    
    const order = orders[orderIndex];
    console.log(`📋 Found order: ${order.orderId}, Status: ${order.orderStatus}, User: ${order.userId}`);
    
    // Check if order belongs to this user
    if (order.userId !== session.userId && order.customerMobile !== session.mobile) {
        console.log(`❌ Order does not belong to this user`);
        return res.status(403).json({ success: false, error: 'You are not authorized to cancel this order' });
    }
    
    // Check if order can be cancelled
    if (order.orderStatus === 'Delivered') {
        console.log(`❌ Cannot cancel - Order already delivered`);
        return res.status(400).json({ success: false, error: 'Cannot cancel delivered order' });
    }
    
    if (order.orderStatus === 'Out for Delivery') {
        console.log(`❌ Cannot cancel - Order out for delivery`);
        return res.status(400).json({ success: false, error: 'Cannot cancel order that is out for delivery' });
    }
    
    if (order.orderStatus === 'Cancelled') {
        console.log(`❌ Order already cancelled`);
        return res.status(400).json({ success: false, error: 'Order already cancelled' });
    }
    
    // Check if within 2 hour cancellation window
    const orderTime = new Date(order.createdAt).getTime();
    const now = Date.now();
    const hoursDiff = (now - orderTime) / (1000 * 60 * 60);
    console.log(`Order placed: ${new Date(order.createdAt).toLocaleString()}`);
    console.log(`Hours since order: ${hoursDiff.toFixed(2)}`);
    
    if (hoursDiff > 2 && order.orderStatus !== 'Confirmed') {
        console.log(`❌ Cannot cancel - Past 2 hour window`);
        return res.status(400).json({ success: false, error: 'Order can only be cancelled within 2 hours of placing' });
    }
    
    // Cancel the order
    orders[orderIndex].orderStatus = 'Cancelled';
    writeJSON(ORDERS_FILE, orders);
    
    console.log(`✅ ORDER CANCELLED SUCCESSFULLY: ${orderId}`);
    console.log('='.repeat(50) + '\n');
    
    res.json({ success: true, message: 'Order cancelled successfully' });
});
