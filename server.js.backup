        csv += `"${u.userId}","${u.mobile}","${u.name || ''}","${u.email || ''}","${u.registeredAt}","${u.lastLoginAt}","${u.totalOrders || 0}"\n`;
    });
    
    res.setHeader('Content-Disposition', 'attachment; filename="chakki_wala_users.csv"');
