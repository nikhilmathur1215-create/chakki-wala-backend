const express = require('express');
const cors = require('cors');
const fs = require('fs');
const path = require('path');

const app = express();
const PORT = 3000;

// Middleware
app.use(cors());
app.use(express.json());

// Data directory
const DATA_DIR = path.join(__dirname, 'data');
if (!fs.existsSync(DATA_DIR)) fs.mkdirSync(DATA_DIR);

// File paths
const USERS_FILE = path.join(DATA_DIR, 'users.json');
const SESSIONS_FILE = path.join(DATA_DIR, 'sessions.json');
const ADDRESSES_FILE = path.join(DATA_DIR, 'addresses.json');
const CARTS_FILE = path.join(DATA_DIR, 'carts.json');
const ORDERS_FILE = path.join(DATA_DIR, 'orders.json');

// Initialize files with empty data
function initFiles() {
    const files = [
        { path: USERS_FILE, default: [] },
        { path: SESSIONS_FILE, default: {} },
        { path: ADDRESSES_FILE, default: [] },
        { path: CARTS_FILE, default: [] },
        { path: ORDERS_FILE, default: [] }
    ];
    
    for (const file of files) {
        if (!fs.existsSync(file.path)) {
            fs.writeFileSync(file.path, JSON.stringify(file.default, null, 2));
            console.log(`✅ Created: ${path.basename(file.path)}`);
        }
    }
}

// Helper functions
function readJSON(filePath) {
    try {
        const data = fs.readFileSync(filePath, 'utf8');
        return JSON.parse(data);
    } catch (err) {
        return [];
    }
}

function writeJSON(filePath, data) {
    fs.writeFileSync(filePath, JSON.stringify(data, null, 2));
}

function generateOTP() {
    return Math.floor(100000 + Math.random() * 900000).toString();
}

function generateId(prefix) {
    return `${prefix}_${Date.now()}_${Math.random().toString(36).substring(2, 8)}`;
}

// Session duration: 6 hours
const SESSION_DURATION = 6 * 60 * 60 * 1000;

// Validate session
function validateSession(sessionId) {
    const sessions = readJSON(SESSIONS_FILE);
    const session = sessions[sessionId];
    
    if (!session) return null;
    
    const now = Date.now();
    if (now > session.expiresAt) {
        delete sessions[sessionId];
        writeJSON(SESSIONS_FILE, sessions);
        return null;
    }
    
    // Refresh expiry
    session.expiresAt = now + SESSION_DURATION;
    writeJSON(SESSIONS_FILE, sessions);
    
    return session;
}

// ==================== AUTH ENDPOINTS ====================

// Send OTP
app.post('/api/auth/send-otp', (req, res) => {
    const { mobile } = req.body;
    console.log(`📱 OTP Request: ${mobile}`);
    
    if (!mobile || !/^\d{10}$/.test(mobile)) {
        return res.status(400).json({ success: false, error: 'Invalid mobile number' });
    }
    
    const otp = generateOTP();
    global.otpStore = global.otpStore || new Map();
    global.otpStore.set(mobile, { otp, expiresAt: Date.now() + 5 * 60 * 1000 });
    
    console.log(`🔑 OTP for ${mobile}: ${otp}`);
    res.json({ success: true, testOtp: otp });
});

// Verify OTP
app.post('/api/auth/verify-otp', (req, res) => {
    const { mobile, otp } = req.body;
    console.log(`\n🔐 Verifying OTP for: ${mobile}`);
    
    global.otpStore = global.otpStore || new Map();
    const stored = global.otpStore.get(mobile);
    
    if (!stored) {
        return res.status(400).json({ success: false, error: 'Request OTP first' });
    }
    
    if (Date.now() > stored.expiresAt) {
        global.otpStore.delete(mobile);
        return res.status(400).json({ success: false, error: 'OTP expired' });
    }
    
    if (stored.otp !== otp) {
        return res.status(400).json({ success: false, error: 'Invalid OTP' });
    }
    
    // Get or create user
    let users = readJSON(USERS_FILE);
    let user = users.find(u => u.mobile === mobile);
    
    if (!user) {
        user = {
            userId: generateId('USR'),
            mobile: mobile,
            name: '',
            email: '',
            registeredAt: new Date().toISOString(),
            lastLoginAt: new Date().toISOString(),
            totalOrders: 0
        };
        users.push(user);
        writeJSON(USERS_FILE, users);
        console.log(`📝 New user: ${mobile}`);
    } else {
        user.lastLoginAt = new Date().toISOString();
        const updatedUsers = users.map(u => u.mobile === mobile ? user : u);
        writeJSON(USERS_FILE, updatedUsers);
        console.log(`🔓 Existing user: ${mobile}`);
    }
    
    // Create session
    const sessionId = generateId('SESS');
    const sessions = readJSON(SESSIONS_FILE);
    sessions[sessionId] = {
        userId: user.userId,
        mobile: user.mobile,
        expiresAt: Date.now() + SESSION_DURATION,
        createdAt: new Date().toISOString()
    };
    writeJSON(SESSIONS_FILE, sessions);
    
    global.otpStore.delete(mobile);
    
    console.log(`✅ Session created: ${sessionId.substring(0, 20)}...`);
    
    res.json({
        success: true,
        sessionId: sessionId,
        user: { userId: user.userId, mobile: user.mobile, name: user.name }
    });
});

// Check session
app.get('/api/auth/check-session', (req, res) => {
    const sessionId = req.headers['x-session-id'];
    if (!sessionId) {
        return res.json({ success: false });
    }
    
    const session = validateSession(sessionId);
    if (!session) {
        return res.json({ success: false });
    }
    
    const user = readJSON(USERS_FILE).find(u => u.userId === session.userId);
    res.json({ success: true, user });
});

// Logout
app.post('/api/auth/logout', (req, res) => {
    const { sessionId } = req.body;
    if (sessionId) {
        const sessions = readJSON(SESSIONS_FILE);
        delete sessions[sessionId];
        writeJSON(SESSIONS_FILE, sessions);
    }
    res.json({ success: true });
});

// ==================== USER PROFILE ====================

app.get('/api/user/profile', (req, res) => {
    const sessionId = req.headers['x-session-id'];
    const session = validateSession(sessionId);
    
    if (!session) {
        return res.status(401).json({ success: false, error: 'Please login' });
    }
    
    const user = readJSON(USERS_FILE).find(u => u.userId === session.userId);
    const addresses = readJSON(ADDRESSES_FILE).filter(a => a.userId === session.userId);
    
    res.json({ success: true, user, addresses });
});

app.put('/api/user/profile', (req, res) => {
    const sessionId = req.headers['x-session-id'];
    const { name, email } = req.body;
    const session = validateSession(sessionId);
    
    if (!session) {
        return res.status(401).json({ success: false, error: 'Please login' });
    }
    
    let users = readJSON(USERS_FILE);
    const index = users.findIndex(u => u.userId === session.userId);
    if (index !== -1) {
        if (name) users[index].name = name;
        if (email) users[index].email = email;
        writeJSON(USERS_FILE, users);
    }
    
    res.json({ success: true });
});

// ==================== ADDRESSES ====================

app.get('/api/user/addresses', (req, res) => {
    const sessionId = req.headers['x-session-id'];
    const session = validateSession(sessionId);
    
    if (!session) {
        return res.status(401).json({ success: false, error: 'Please login' });
    }
    
    const addresses = readJSON(ADDRESSES_FILE).filter(a => a.userId === session.userId);
    res.json({ success: true, addresses });
});

app.post('/api/user/addresses', (req, res) => {
    const sessionId = req.headers['x-session-id'];
    const session = validateSession(sessionId);
    
    if (!session) {
        return res.status(401).json({ success: false, error: 'Please login' });
    }
    
    let addresses = readJSON(ADDRESSES_FILE);
    const { addressId, label, recipientName, recipientMobile, addressLine1, addressLine2, city, state, pincode, landmark, isDefault } = req.body;
    
    if (addressId) {
        // Update existing
        const index = addresses.findIndex(a => a.addressId === addressId);
        if (index !== -1) {
            addresses[index] = { ...addresses[index], label, recipientName, recipientMobile, addressLine1, addressLine2, city, state, pincode, landmark, isDefault, updatedAt: new Date().toISOString() };
        }
    } else {
        // Create new
        const newAddress = {
            addressId: generateId('ADR'),
            userId: session.userId,
            label: label || 'Home',
            recipientName,
            recipientMobile,
            addressLine1,
            addressLine2: addressLine2 || '',
            city,
            state,
            pincode,
            landmark: landmark || '',
            isDefault: isDefault || addresses.filter(a => a.userId === session.userId).length === 0,
            createdAt: new Date().toISOString()
        };
        addresses.push(newAddress);
        
        // Update user name if first address
        if (addresses.filter(a => a.userId === session.userId).length === 1 && recipientName) {
            let users = readJSON(USERS_FILE);
            const userIndex = users.findIndex(u => u.userId === session.userId);
            if (userIndex !== -1 && !users[userIndex].name) {
                users[userIndex].name = recipientName;
                writeJSON(USERS_FILE, users);
            }
        }
    }
    
    writeJSON(ADDRESSES_FILE, addresses);
    res.json({ success: true });
});

app.delete('/api/user/addresses/:addressId', (req, res) => {
    const sessionId = req.headers['x-session-id'];
    const { addressId } = req.params;
    const session = validateSession(sessionId);
    
    if (!session) {
        return res.status(401).json({ success: false, error: 'Please login' });
    }
    
    let addresses = readJSON(ADDRESSES_FILE);
    addresses = addresses.filter(a => a.addressId !== addressId);
    writeJSON(ADDRESSES_FILE, addresses);
    
    res.json({ success: true });
});

// ==================== CART ====================

app.get('/api/cart', (req, res) => {
    const sessionId = req.headers['x-session-id'];
    const session = validateSession(sessionId);
    
    if (!session) {
        return res.status(401).json({ success: false, error: 'Please login' });
    }
    
    const carts = readJSON(CARTS_FILE);
    const cart = carts.find(c => c.userId === session.userId) || { items: [] };
    
    res.json({ success: true, cart: cart.items, cartCount: cart.items.reduce((s, i) => s + i.quantity, 0) });
});

app.post('/api/cart/add', (req, res) => {
    const sessionId = req.headers['x-session-id'];
    const session = validateSession(sessionId);
    
    if (!session) {
        return res.status(401).json({ success: false, error: 'Please login' });
    }
    
    let carts = readJSON(CARTS_FILE);
    let cartIndex = carts.findIndex(c => c.userId === session.userId);
    let items = cartIndex !== -1 ? [...carts[cartIndex].items] : [];
    
    const { productId, name, price, weight, quantity, image } = req.body;
    
    const existingIndex = items.findIndex(i => i.productId === productId && i.weight === weight);
    if (existingIndex !== -1) {
        items[existingIndex].quantity += quantity;
    } else {
        items.push({ productId, name, price, weight, quantity, image, addedAt: new Date().toISOString() });
    }
    
    if (cartIndex !== -1) {
        carts[cartIndex].items = items;
        carts[cartIndex].updatedAt = new Date().toISOString();
    } else {
        carts.push({ userId: session.userId, items, updatedAt: new Date().toISOString() });
    }
    
    writeJSON(CARTS_FILE, carts);
    
    const cartCount = items.reduce((s, i) => s + i.quantity, 0);
    res.json({ success: true, cartCount });
});

app.put('/api/cart/update', (req, res) => {
    const sessionId = req.headers['x-session-id'];
    const { productId, weight, quantity } = req.body;
    const session = validateSession(sessionId);
    
    if (!session) {
        return res.status(401).json({ success: false, error: 'Please login' });
    }
    
    let carts = readJSON(CARTS_FILE);
    let cartIndex = carts.findIndex(c => c.userId === session.userId);
    
    if (cartIndex === -1) {
        return res.json({ success: true });
    }
    
    let items = carts[cartIndex].items;
    
    if (quantity <= 0) {
        items = items.filter(i => !(i.productId === productId && i.weight === weight));
    } else {
        const index = items.findIndex(i => i.productId === productId && i.weight === weight);
        if (index !== -1) items[index].quantity = quantity;
    }
    
    carts[cartIndex].items = items;
    carts[cartIndex].updatedAt = new Date().toISOString();
    writeJSON(CARTS_FILE, carts);
    
    res.json({ success: true });
});

app.delete('/api/cart/remove', (req, res) => {
    const sessionId = req.headers['x-session-id'];
    const { productId, weight } = req.body;
    const session = validateSession(sessionId);
    
    if (!session) {
        return res.status(401).json({ success: false, error: 'Please login' });
    }
    
    let carts = readJSON(CARTS_FILE);
    let cartIndex = carts.findIndex(c => c.userId === session.userId);
    
    if (cartIndex !== -1) {
        carts[cartIndex].items = carts[cartIndex].items.filter(i => !(i.productId === productId && i.weight === weight));
        writeJSON(CARTS_FILE, carts);
    }
    
    res.json({ success: true });
});

app.post('/api/cart/sync', (req, res) => {
    const sessionId = req.headers['x-session-id'];
    const { localCart } = req.body;
    const session = validateSession(sessionId);
    
    if (!session) {
        return res.status(401).json({ success: false, error: 'Please login' });
    }
    
    let carts = readJSON(CARTS_FILE);
    let cartIndex = carts.findIndex(c => c.userId === session.userId);
    let backendItems = cartIndex !== -1 ? [...carts[cartIndex].items] : [];
    
    // Merge local cart with backend cart
    for (const localItem of localCart) {
        const existingIndex = backendItems.findIndex(i => i.productId === localItem.productId && i.weight === localItem.weight);
        if (existingIndex !== -1) {
            backendItems[existingIndex].quantity += localItem.quantity;
        } else {
            backendItems.push(localItem);
        }
    }
    
    if (cartIndex !== -1) {
        carts[cartIndex].items = backendItems;
        carts[cartIndex].updatedAt = new Date().toISOString();
    } else {
        carts.push({ userId: session.userId, items: backendItems, updatedAt: new Date().toISOString() });
    }
    
    writeJSON(CARTS_FILE, carts);
    res.json({ success: true });
});

// ==================== ORDERS ====================

app.post('/api/order/place', (req, res) => {
    const sessionId = req.headers['x-session-id'];
    const { address, deliverySlot, paymentMethod, orderDetails } = req.body;
    const session = validateSession(sessionId);
    
    console.log('\n' + '='.repeat(50));
    console.log('🛒 ORDER PLACEMENT REQUEST');
    
    if (!session) {
        console.log('❌ No session');
        return res.status(401).json({ success: false, error: 'Please login' });
    }
    
    const user = readJSON(USERS_FILE).find(u => u.userId === session.userId);
    const cart = readJSON(CARTS_FILE).find(c => c.userId === session.userId);
    const items = orderDetails?.items || cart?.items || [];
    
    if (items.length === 0) {
        console.log('❌ Empty cart');
        return res.status(400).json({ success: false, error: 'Cart is empty' });
    }
    
    let subtotal = 0;
    items.forEach(item => { subtotal += item.price * item.quantity; });
    const gst = subtotal * 0.05;
    const deliveryFee = subtotal >= 500 ? 0 : 40;
    const total = subtotal + deliveryFee + gst;
    
    const orderId = `CKW-${Date.now()}`;
    const now = new Date();
    
    const newOrder = {
        orderId,
        orderDate: now.toISOString().split('T')[0],
        orderTime: now.toLocaleTimeString(),
        orderStatus: 'Confirmed',
        paymentMethod: paymentMethod || 'COD',
        deliverySlot,
        customerName: address.recipientName || user.name,
        customerMobile: address.recipientMobile || user.mobile,
        userId: session.userId,
        subtotal, gst, deliveryFee, orderTotal: total,
        address,
        items: items.map(i => ({ name: i.name, weight: i.weight, quantity: i.quantity, price: i.price })),
        createdAt: now.toISOString()
    };
    
    let orders = readJSON(ORDERS_FILE);
    orders.unshift(newOrder);
    writeJSON(ORDERS_FILE, orders);
    
    // Clear cart
    let carts = readJSON(CARTS_FILE);
    const cartIndex = carts.findIndex(c => c.userId === session.userId);
    if (cartIndex !== -1) {
        carts[cartIndex].items = [];
        writeJSON(CARTS_FILE, carts);
    }
    
    // Update user order count
    let users = readJSON(USERS_FILE);
    const userIndex = users.findIndex(u => u.userId === session.userId);
    if (userIndex !== -1) {
        users[userIndex].totalOrders++;
        writeJSON(USERS_FILE, users);
    }
    
    console.log(`✅ ORDER PLACED: ${orderId}`);
    console.log(`   Total: ₹${total}`);
    console.log('='.repeat(50) + '\n');
    
    res.json({ success: true, orderId, orderTotal: total });
});

app.get('/api/orders', (req, res) => {
    const sessionId = req.headers['x-session-id'];
    const session = validateSession(sessionId);
    
    if (!session) {
        return res.status(401).json({ success: false, error: 'Please login' });
    }
    
    const orders = readJSON(ORDERS_FILE);
    const userOrders = orders.filter(o => o.userId === session.userId);
    res.json({ success: true, orders: userOrders });
});

