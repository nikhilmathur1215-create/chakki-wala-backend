// Also serve /admin.html as fallback
app.get('/admin.html', (req, res) => {
    const adminPath = path.join(__dirname, 'public', 'admin.html');
    if (fs.existsSync(adminPath)) {
        res.sendFile(adminPath);
    } else {
        res.status(404).send('Admin panel not found');
    }
});

// Updated Export Orders CSV with Address
app.get('/api/export/csv', (req, res) => {
    const { adminKey } = req.query;
    if (adminKey !== 'chakkiwala@2024') {
        return res.status(401).json({ success: false });
    }
    
    const orders = readJSON(ORDERS_FILE);
    
    // CSV Headers with Address fields
    let csv = 'Order ID,Order Date,Order Time,Status,Payment Method,Delivery Slot,Customer Name,Customer Mobile,';
    csv += 'Recipient Name,Recipient Mobile,Address Line 1,Address Line 2,City,State,Pincode,Landmark,';
    csv += 'Subtotal,Delivery Fee,GST (5%),Total Amount,Items\n';
    
    for (const order of orders) {
        // Format address fields
        let address = order.address || {};
        if (typeof address === 'string') {
            // If address is stored as string, try to parse or use as is
            try {
                address = JSON.parse(address);
            } catch(e) {
                address = { fullAddress: address };
            }
        }
        
        const recipientName = address.recipientName || order.customerName || '';
        const recipientMobile = address.recipientMobile || order.customerMobile || '';
        const addressLine1 = address.addressLine1 || '';
        const addressLine2 = address.addressLine2 || '';
        const city = address.city || '';
        const state = address.state || '';
        const pincode = address.pincode || '';
        const landmark = address.landmark || '';
        
        // Format items
        const items = (order.items || []).map(i => `${i.name} (${i.weight}) x${i.quantity} = ₹${i.price * i.quantity}`).join('; ');
        
        csv += `"${order.orderId}","${order.orderDate}","${order.orderTime}","${order.orderStatus}","${order.paymentMethod || 'COD'}","${order.deliverySlot || ''}",`;
        csv += `"${order.customerName || ''}","${order.customerMobile || ''}",`;
        csv += `"${recipientName}","${recipientMobile}","${addressLine1}","${addressLine2}","${city}","${state}","${pincode}","${landmark}",`;
        csv += `"${order.subtotal || 0}","${order.deliveryFee === 0 ? 'FREE' : order.deliveryFee || 0}","${order.gst || 0}","${order.orderTotal || 0}","${items}"\n`;
    }
    
    res.setHeader('Content-Disposition', 'attachment; filename="chakki_wala_orders.csv"');
    res.setHeader('Content-Type', 'text/csv');
    res.send(csv);
});

// Export Users CSV with their saved addresses
app.get('/api/admin/export-users-csv', (req, res) => {
    const { adminKey } = req.query;
    if (adminKey !== 'chakkiwala@2024') {
        return res.status(401).json({ success: false });
    }
    
    const users = readJSON(USERS_FILE);
    const addresses = readJSON(ADDRESSES_FILE);
    const orders = readJSON(ORDERS_FILE);
    
    // CSV Headers
    let csv = 'User ID,Mobile,Name,Email,Registered Date,Last Login,Total Orders,';
    csv += 'Default Address Label,Default Recipient Name,Default Recipient Mobile,';
    csv += 'Default Address Line 1,Default Address Line 2,Default City,Default State,Default Pincode,Default Landmark,';
    csv += 'All Saved Addresses\n';
    
    for (const user of users) {
        // Get user's orders count
        const userOrders = orders.filter(o => o.userId === user.userId || o.customerMobile === user.mobile);
        const totalOrders = userOrders.length;
        
        // Get user's addresses
        const userAddresses = addresses.filter(a => a.userId === user.userId);
        const defaultAddress = userAddresses.find(a => a.isDefault) || userAddresses[0];
        
        // Format default address fields
        let defaultLabel = '';
        let defaultRecipientName = '';
        let defaultRecipientMobile = '';
        let defaultAddressLine1 = '';
        let defaultAddressLine2 = '';
        let defaultCity = '';
        let defaultState = '';
        let defaultPincode = '';
        let defaultLandmark = '';
        
        if (defaultAddress) {
            defaultLabel = defaultAddress.label || '';
            defaultRecipientName = defaultAddress.recipientName || user.name || '';
            defaultRecipientMobile = defaultAddress.recipientMobile || user.mobile || '';
            defaultAddressLine1 = defaultAddress.addressLine1 || '';
            defaultAddressLine2 = defaultAddress.addressLine2 || '';
            defaultCity = defaultAddress.city || '';
            defaultState = defaultAddress.state || '';
            defaultPincode = defaultAddress.pincode || '';
            defaultLandmark = defaultAddress.landmark || '';
        }
        
        // Format all addresses as JSON string
        const allAddresses = userAddresses.map(addr => {
            return `${addr.label}: ${addr.addressLine1}, ${addr.addressLine2 || ''}, ${addr.city}, ${addr.state} - ${addr.pincode} (${addr.recipientName})`;
        }).join(' | ');
        
        csv += `"${user.userId}","${user.mobile}","${user.name || ''}","${user.email || ''}",`;
        csv += `"${user.registeredAt || ''}","${user.lastLoginAt || ''}","${totalOrders}",`;
        csv += `"${defaultLabel}","${defaultRecipientName}","${defaultRecipientMobile}",`;
        csv += `"${defaultAddressLine1}","${defaultAddressLine2}","${defaultCity}","${defaultState}","${defaultPincode}","${defaultLandmark}",`;
        csv += `"${allAddresses}"\n`;
    }
    
    res.setHeader('Content-Disposition', 'attachment; filename="chakki_wala_users.csv"');
    res.setHeader('Content-Type', 'text/csv');
    res.send(csv);
});

// ==================== FIXED EXPORT ORDERS CSV WITH ADDRESS ====================
// Replace the existing /api/export/csv endpoint with this version

// First, find and remove the old endpoint if it exists
// Then add this new one

app.get('/api/export/csv', (req, res) => {
    const { adminKey } = req.query;
    if (adminKey !== 'chakkiwala@2024') {
        return res.status(401).json({ success: false });
    }
    
    const orders = readJSON(ORDERS_FILE);
    console.log(`📊 Exporting ${orders.length} orders to CSV with address column`);
    
    // CSV Headers - ADDED ADDRESS COLUMN
    let csv = 'Order ID,Order Date,Order Time,Status,Payment Method,Delivery Slot,Customer Name,Customer Mobile,ADDRESS,Subtotal,Delivery Fee,GST (5%),Total Amount,Items\n';
    
    for (const order of orders) {
        // Extract address - handle different formats
        let addressText = '';
        
        if (order.address) {
            if (typeof order.address === 'string') {
                addressText = order.address;
            } else if (order.address.fullAddress) {
                addressText = order.address.fullAddress;
            } else if (order.address.addressLine1) {
                addressText = `${order.address.addressLine1}`;
                if (order.address.addressLine2) addressText += `, ${order.address.addressLine2}`;
                if (order.address.city) addressText += `, ${order.address.city}`;
                if (order.address.state) addressText += `, ${order.address.state}`;
                if (order.address.pincode) addressText += ` - ${order.address.pincode}`;
            } else {
                addressText = JSON.stringify(order.address);
            }
        }
        
        // Clean address text for CSV (remove commas, quotes)
        addressText = addressText.replace(/,/g, ';').replace(/"/g, "'");
        
        // Format items
        const items = (order.items || []).map(i => {
            return `${i.name} (${i.weight || '1kg'}) x${i.quantity} = ₹${(i.price || 0) * (i.quantity || 1)}`;
        }).join(' | ');
        
        csv += `"${order.orderId || ''}",`;
        csv += `"${order.orderDate || ''}",`;
        csv += `"${order.orderTime || ''}",`;
        csv += `"${order.orderStatus || 'Confirmed'}",`;
        csv += `"${order.paymentMethod || 'COD'}",`;
        csv += `"${order.deliverySlot || ''}",`;
        csv += `"${order.customerName || ''}",`;
        csv += `"${order.customerMobile || ''}",`;
        csv += `"${addressText}",`;  // ← ADDRESS COLUMN ADDED HERE
        csv += `${order.subtotal || 0},`;
        csv += `${order.deliveryFee === 0 ? 'FREE' : (order.deliveryFee || 0)},`;
        csv += `${order.gst || 0},`;
        csv += `${order.orderTotal || 0},`;
        csv += `"${items}"\n`;
    }
    
    res.setHeader('Content-Disposition', 'attachment; filename="chakki_wala_orders.csv"');
    res.setHeader('Content-Type', 'text/csv; charset=utf-8');
    res.send(csv);
    
    console.log(`✅ Orders CSV exported with address column`);
});

