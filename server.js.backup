app.get('/api/export/csv', (req, res) => {
    const { adminKey } = req.query;
    if (adminKey !== 'chakkiwala@2024') {
        return res.status(401).json({ success: false });
    }
    
    const orders = readJSON(ORDERS_FILE);
    let csv = 'Order ID,Date,Time,Status,Customer,Mobile,Total,Items\n';
    orders.forEach(o => {
        const items = (o.items || []).map(i => `${i.name} x${i.quantity}`).join('; ');
        csv += `"${o.orderId}","${o.orderDate}","${o.orderTime}","${o.orderStatus}","${o.customerName}","${o.customerMobile}","${o.orderTotal}","${items}"\n`;
    });
    
    res.setHeader('Content-Disposition', 'attachment; filename="chakki_wala_orders.csv"');
    res.setHeader('Content-Type', 'text/csv');
    res.send(csv);
});

app.get('/api/admin/slots', (req, res) => {
    const { adminKey } = req.query;
    if (adminKey !== 'chakkiwala@2024') {
        return res.status(401).json({ success: false });
    }
    
    const slots = [
        { id: 'slot1', name: 'Morning', time: '12:00 PM - 04:00 PM', startHour: 12, isAvailable: true },
        { id: 'slot2', name: 'Evening', time: '04:00 PM - 08:00 PM', startHour: 16, isAvailable: true },
        { id: 'slot3', name: 'Night', time: '08:00 PM - 10:00 PM', startHour: 20, isAvailable: true }
    ];
    
    const now = new Date();
    const currentHour = now.getHours();
    const updatedSlots = slots.map(slot => ({
        ...slot,
        isAvailable: slot.startHour > currentHour + 2
    }));
    
    res.json({ success: true, slots: updatedSlots });
});

app.post('/api/admin/update-slot', (req, res) => {
