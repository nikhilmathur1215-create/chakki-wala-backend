// Add CSP headers for admin panel
app.use((req, res, next) => {
    res.setHeader('Content-Security-Policy', "default-src * 'unsafe-inline' 'unsafe-eval' data: blob:;");
    res.setHeader('Access-Control-Allow-Origin', '*');
    res.setHeader('Access-Control-Allow-Methods', 'GET, POST, PUT, DELETE, OPTIONS');
    res.setHeader('Access-Control-Allow-Headers', 'Content-Type, X-Session-Id');
    next();
});

// Export users as CSV
app.get('/api/admin/export-users-csv', (req, res) => {
    const { adminKey } = req.query;
    if (adminKey !== 'chakkiwala@2024') {
        return res.status(401).json({ success: false });
    }
    
    const users = readJSON(USERS_FILE);
    let csv = 'User ID,Mobile,Name,Email,Registered Date,Last Login,Total Orders\n';
    
    users.forEach(user => {
        const userOrders = orders.filter(o => o.userId === user.userId || o.customerMobile === user.mobile);
        csv += `"${user.userId}","${user.mobile}","${user.name || ''}","${user.email || ''}","${user.registeredAt || ''}","${user.lastLoginAt || ''}","${userOrders.length}"\n`;
    });
    
    res.setHeader('Content-Disposition', 'attachment; filename="chakki_wala_users.csv"');
    res.setHeader('Content-Type', 'text/csv');
    res.send(csv);
});

